<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TeamsNowPlaying.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="TeamsNowPlaying.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="500" Height="720"
        MinWidth="400" MinHeight="500"
        Icon="/Assets/app-icon.ico"
        Title="Teams Now Playing — Settings">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Status Bar & Version — always visible at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,16" Spacing="8">
            <Border Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                    CornerRadius="6" Padding="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding CurrentTrackDisplay}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LastUpdateStatus}" Opacity="0.7" FontSize="12"/>
                </StackPanel>
            </Border>
            <TextBlock Text="{Binding VersionDisplay}" Opacity="0.4" FontSize="11"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Scrollable settings -->
        <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">

                <!-- Spotify Section -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Spotify" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SpotifyStatus}" Opacity="0.7"/>
                        <TextBox Watermark="Spotify Client ID"
                                 Text="{Binding SpotifyClientId, Mode=TwoWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Connect" Command="{Binding ConnectSpotifyCommand}"
                                    IsVisible="{Binding !IsSpotifyConnected}" />
                            <Button Content="Disconnect" Command="{Binding DisconnectSpotifyCommand}"
                                    IsVisible="{Binding IsSpotifyConnected}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Teams Section -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Microsoft Teams" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TeamsStatus}" Opacity="0.7"/>
                        <TextBox Watermark="Azure AD Client ID"
                                 Text="{Binding TeamsClientId, Mode=TwoWay}" />
                        <TextBox Watermark="Tenant ID (default: common)"
                                 Text="{Binding TeamsTenantId, Mode=TwoWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Connect" Command="{Binding ConnectTeamsCommand}"
                                    IsVisible="{Binding !IsTeamsConnected}" />
                            <Button Content="Disconnect" Command="{Binding DisconnectTeamsCommand}"
                                    IsVisible="{Binding IsTeamsConnected}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Status Format -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Status Format" FontSize="16" FontWeight="Bold"/>
                        <TextBlock Text="Use {artist} and {title} as placeholders" Opacity="0.7"/>
                        <TextBox Text="{Binding StatusFormat, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

                <!-- Polling -->
                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Polling" FontSize="16" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Interval:" VerticalAlignment="Center"/>
                            <Slider Minimum="5" Maximum="60"
                                    Value="{Binding PollIntervalSeconds, Mode=TwoWay}"
                                    Width="250" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PollIntervalSeconds, StringFormat={}{0}s}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <CheckBox Content="Enable automatic updates"
                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
